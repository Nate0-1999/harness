# Local/operator configuration only. Copy to .env, keep it untracked, and
# chmod 0600. Cloud runtime secrets live in Secret Manager.
SPINE_TOKEN=
SPINE_URL=http://localhost:8000
PRINCIPAL_ID=local
MACHINE_ID=local-machine
AGENT_ID=harness-agent
ANTHROPIC_API_KEY=
# Optional direct-provider compatibility; unused by the default broker route.
OPENAI_API_KEY=
# D1 maps this through Secret Manager to Spine's SPINE_OPENAI_API_KEY slot.
OPENROUTER_API_KEY=
CHAT_MODEL=openrouter:minimax/minimax-m3
# Keep this aligned with CHAT_MODEL's actual context window.
MODEL_CONTEXT_TOKENS=1000000
